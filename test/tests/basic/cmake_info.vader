Before:
    silent call OpenTestProject()
    silent call RemoveCMakeDirs()

    silent call ResetPluginOptions()
    " Use on in order to close all windows and avoid E36 error
    silent on

After:
    silent call RemoveCMakeDirs()

Execute ([CMake info] Get CMake info):
    Assert !isdirectory("cmake-build-Release"), "Build directory shouldn't exist"
    silent CMake
    Assert filereadable("cmake-build-Release/CMakeCache.txt"), "CMakeCache.txt should be generated"
    let info = utils#cmake#common#getInfo()
    let result = utils#window#PrepareInfo(info)
    " One extra line per detected compiler when the toolchains file API object
    " is available (CMake 3.27+)
    let expected = 10 + (has_key(info, 'toolchains') ? len(info['toolchains']) : 0)
    Assert len(result) == expected, "test project should contain " . expected . " lines with cmake info, got " . len(result)

Execute ([CMake info] Toolchains compilers are detected on CMake 3.27+):
    if utils#cmake#version#verNewerOrEq([3, 27])
        silent CMake
        let info = utils#cmake#common#getInfo()
        Assert has_key(info, 'toolchains'), "toolchains info should be present"
        Assert has_key(info['toolchains'], 'CXX'), "CXX compiler should be detected"
    endif

Execute ([CMake info] Get CMake info for empty project):
    Assert !isdirectory("cmake-build-Release"), "Build directory shouldn't exist"
    silent CMakeInfo

Expect text ([CMake info] check CMake info for empty project):
  CMake project was not found!

Execute ([CMake info] Close CMakeInfo Window):
    let window_counter = 0
    windo let window_counter = window_counter + 1
    AssertEqual window_counter, 1
    silent CMakeInfo
    let window_counter = 0
    windo let window_counter = window_counter + 1
    AssertEqual window_counter, 2
    call utils#window#CloseCMakeInfoWindow()
    let window_counter = 0
    windo let window_counter = window_counter + 1
    AssertEqual window_counter, 1

Execute ([CMake info] Get cmake info 2 times):
    Assert !isdirectory("cmake-build-Release"), "Build directory shouldn't exist"
    silent CMakeInfo
    silent CMakeInfo
